<%# Vista: Detalle de un grupo con tabla de posiciones %>

<div class="page-header">
  <h1 class="page-title">Grupo <%= @grupo.nombre %></h1>
  <div style="display: flex; gap: 8px;">
    <%= link_to "＋ Agregar selección", new_seleccion_path(grupo_id: @grupo.id), class: "btn-primary" %>
    <%= link_to "Editar grupo", edit_grupo_path(@grupo), class: "btn-secondary" %>
    <%= link_to "← Volver", grupos_path, class: "btn-secondary" %>
  </div>
</div>

<h2 style="font-size: 16px; color: #0A1F44; margin-bottom: 0.75rem; font-weight: bold;">
  Tabla de posiciones
</h2>

<% if @selecciones.empty? %>
  <div class="card" style="text-align: center; color: #888; padding: 2rem;">
    <p>No hay selecciones en este grupo aún.</p>
    <%= link_to "Agregar selección", new_seleccion_path(grupo_id: @grupo.id), class: "btn-primary", style: "margin-top: 1rem; display: inline-block;" %>
  </div>
<% else %>
  <table class="tabla" style="margin-bottom: 1.5rem;">
    <thead>
      <tr>
        <th>#</th>
        <th>Selección</th>
        <th style="text-align: center;">GF</th>
        <th style="text-align: center;">GC</th>
        <th style="text-align: center;">DG</th>
        <th style="text-align: center;">Pts</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% @selecciones.each_with_index do |seleccion, index| %>
        <tr style="<%= index < 2 ? 'background: #f0f6ff;' : '' %>">
          <td style="font-weight: bold; color: #0A1F44;"><%= index + 1 %></td>
          <td>
            <span style="background:#0A1F44; color:#C9A84C; font-size:10px; font-weight:bold;
                         padding:2px 5px; border-radius:4px; font-family:monospace; margin-right:5px;">
              <%= seleccion.codigo %>
            </span>
            <%= seleccion.pais %>
            <% if index < 2 %>
              <span class="badge badge-blue" style="font-size: 11px; margin-left: 4px;">Clasifica</span>
            <% end %>
          </td>
          <td style="text-align: center;"><%= seleccion.goles_favor %></td>
          <td style="text-align: center;"><%= seleccion.goles_contra %></td>
          <td style="text-align: center;"><%= seleccion.diferencia_goles %></td>
          <td style="text-align: center; font-weight: bold; color: #0A1F44;"><%= seleccion.puntos %></td>
          <td>
            <div class="acciones">
              <%= link_to "Editar", edit_seleccion_path(seleccion), class: "btn-primary", style: "font-size: 12px; padding: 4px 10px;" %>
              <%= button_to "Eliminar", seleccion_path(seleccion), method: :delete,
                  form: { onsubmit: "return confirm('¿Eliminar a #{seleccion.pais} del Grupo #{@grupo.nombre}? Esta acción no se puede deshacer.')" },
                  class: "btn-danger", style: "font-size: 12px; padding: 4px 10px;" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p style="font-size: 12px; color: #888;">
    Los primeros 2 de cada grupo clasifican a la fase de eliminación directa.
  </p>
<% end %>
