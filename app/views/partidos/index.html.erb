<div class="page-header">
  <h1 class="page-title">Registro de Resultados</h1>
</div>

<div class="card">
  <h2 style="margin-bottom: 1rem;">Seleccionar Grupo</h2>

  <%= form_with url: partidos_path,
                method: :get,
                local: true do %>

    <div style="display:flex; gap:10px; align-items:center;">
      <%= select_tag :grupo_id,
          options_from_collection_for_select(
            @grupos,
            :id,
            :nombre,
            params[:grupo_id]
          ),
          style: "padding:8px; min-width:200px;" %>

      <%= submit_tag "Buscar",
            class: "btn-primary" %>
    </div>

  <% end %>
</div>

<% if @grupo %>

  <div class="card">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
      <h2 style="color:#0A1F44;">
        Grupo <%= @grupo.nombre %>
      </h2>

      <span class="badge badge-gold">
        <%= @partidos.count %> partidos
      </span>
    </div>

    <% if @partidos.empty? %>

      <p style="color:#777;">
        Este grupo aún no tiene partidos generados.
      </p>

      <%= button_to "Generar Partidos",
            generar_partidos_path(grupo_id: @grupo.id),
            method: :post,
            class: "btn-primary" %>

    <% else %>

      <table class="table">
        <thead>
          <tr>
            <th>Partido</th>
            <th>Estado</th>
            <th>Acción</th>
          </tr>
        </thead>

        <tbody>

          <% @partidos.each do |partido| %>

            <tr>

              <td>

                <% if partido.jugado %>

                  <strong>
                    <%= partido.seleccion_a.pais %>
                    <%= partido.goles_a %>
                    -
                    <%= partido.goles_b %>
                    <%= partido.seleccion_b.pais %>
                  </strong>

                <% else %>

                  <%= partido.seleccion_a.pais %>
                  vs
                  <%= partido.seleccion_b.pais %>

                <% end %>

              </td>

              <td>

                <% if partido.jugado %>

                  <span class="badge badge-gold">
                    Jugado
                  </span>

                <% else %>

                  <span class="badge badge-blue">
                    Pendiente
                  </span>

                <% end %>

              </td>

              <td>

                <% if partido.jugado %>

                  <%= link_to "Editar",
                        edit_partido_path(partido),
                        class: "btn-secondary",
                        style: "width: 100px; text-align: center;" %>

                <% else %>

                  <%= link_to "Registrar",
                        edit_partido_path(partido),
                        class: "btn-primary",
                        style: "width: 100px; text-align: center;" %>

                <% end %>

              </td>

            </tr>

          <% end %>

        </tbody>
      </table>

    <% end %>

  </div>

<% end %>